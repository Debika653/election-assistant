{
  "entities": {
    "user_profiles": {
      "title": "User Profile",
      "description": "User specific data including checklist and eligibility status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user (Auth UID)" },
        "checklist": {
          "type": "array",
          "description": "The voter tasklist state",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "completed": { "type": "boolean" },
              "category": { "type": "string" }
            }
          }
        },
        "eligibility": {
          "type": "object",
          "properties": {
            "isIndian": { "type": ["boolean", "null"] },
            "isAgeEligible": { "type": ["boolean", "null"] },
            "isResident": { "type": ["boolean", "null"] }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user_profiles",
      "description": "Individual user documents containing their progress and settings"
    }
  }
}
